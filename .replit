modules = ["web", "java-graalvm22.3", "python-base-3.13"]

[nix]
channel = "stable-25_05"
packages = ["iana-etc"]

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd CampoMinado && mvn package -q && cd .. && python3 server.py"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "vm"
run = ["python3", "server.py"]
build = ["bash", "-c", "cd CampoMinado && mvn package -q"]
